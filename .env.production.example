# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# Domain: pareeduhub.com
# ============================================

# Application
APP_NAME="Pareeduhub"
APP_ENV=production
APP_KEY=base64:GENERATE_NEW_KEY_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://pareeduhub.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

# Application Maintenance
APP_MAINTENANCE_DRIVER=file

# Database - Sesuaikan dengan kredensial hosting production
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pareeduhub_db
DB_USERNAME=pareeduhub_user
DB_PASSWORD=STRONG_PASSWORD_HERE

# Session & Cache - Gunakan database atau Redis untuk production
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.pareeduhub.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=pareeduhub_cache

# Mail Configuration - Gunakan SMTP production (Gmail, SendGrid, Mailtrap, dll)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@pareeduhub.com
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@pareeduhub.com
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# PAYMENT GATEWAY CONFIGURATION
# ============================================

# Default Payment Gateway
PAYMENT_DEFAULT_GATEWAY=flip

# MIDTRANS - PRODUCTION CREDENTIALS
MIDTRANS_SERVER_KEY=YOUR_PRODUCTION_SERVER_KEY
MIDTRANS_CLIENT_KEY=YOUR_PRODUCTION_CLIENT_KEY
MIDTRANS_IS_PRODUCTION=true
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

# FLIP - PRODUCTION CREDENTIALS
FLIP_SECRET_KEY=YOUR_PRODUCTION_FLIP_SECRET_KEY
FLIP_VALIDATION_TOKEN=YOUR_PRODUCTION_FLIP_VALIDATION_TOKEN
FLIP_IS_PRODUCTION=true
FLIP_BASE_URL=https://bigflip.id/api/v2
FLIP_BILL_EXPIRY_HOURS=24
FLIP_PAYMENT_STEP=2
FLIP_ADDRESS_REQUIRED=false
FLIP_PHONE_REQUIRED=false

# ============================================
# SECURITY & PERFORMANCE
# ============================================

# Logging
LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Vite
VITE_APP_NAME="${APP_NAME}"

# AWS (jika menggunakan S3 untuk file storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# Pusher (jika menggunakan real-time features)
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_HOST=
# PUSHER_PORT=443
# PUSHER_SCHEME=https
# PUSHER_APP_CLUSTER=ap1

# Redis (optional, untuk performance)
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# Sanctum
SANCTUM_STATEFUL_DOMAINS=pareeduhub.com,www.pareeduhub.com

# CORS
CORS_ALLOWED_ORIGINS=https://pareeduhub.com,https://www.pareeduhub.com
